#!/bin/bash
# zpwa - The Zen PWA Suite CLI Dispatcher

# --- EXTENDED GLOBBING ---
shopt -s extglob

export BASE_DIR="$HOME/.zpwa"
export MASTER_SOURCE="/usr/share/zpwa"
export SCRIPT_DIR="$BASE_DIR/scripts"
export PWA_MONITOR="$SCRIPT_DIR/pwa_monitor.sh"

# --- INITIALIZATION ---
if [ -f "$BASE_DIR/variables/variables.sh" ]; then
    source "$BASE_DIR/variables/variables.sh"
    INITIALIZED=true
else
    INITIALIZED=false
fi

present_terminal() {
    omarchy-launch-floating-terminal-with-presentation "$1"
}

show_help() {
    echo "Zen PWA Suite (zpwa) - CLI"
    echo "--------------------------"
    if [ "$INITIALIZED" = false ]; then
        echo "Status: [ NOT INITIALIZED ]"
        echo "Usage:  zpwa setup"
    else
        echo "Status: [ INITIALIZED ]"
        echo "Usage:  zpwa [command]"
        echo ""
        echo "Commands:"
        echo "  install       New Zen PWA"
        echo "  rm [--all]    Remove PWAs"
        echo "  ls            List PWAs"
        echo "  update        Sync binds/templates"
        echo "  monitor       Run PWA monitor (verbose)"
        echo ""
        echo "Maintenance:"
        echo "  setup         Re-run environment initialization"
        echo "  revert        Restore original system state"
        echo "  menu-change   Change menu integration style"
        echo "  restore       [menu|binds] Select and restore snapshots"
    fi
    echo "  -h, --help    Show this menu"
}

# --- INTERNAL UTILITIES ---

do_restore() {
    local target=$1
    local snap_dir="$BASE_DIR/snapshots/$target"
    local config_file

    [[ "$target" == "menu" ]] && config_file="$HOME/.config/omarchy/extensions/menu.sh"
    [[ "$target" == "bind" ]] && config_file="$HOME/.config/hypr/bindings.conf"

    if [[ ! -d "$snap_dir" ]] || ! ls "$snap_dir"/*.bak >/dev/null 2>&1; then
        echo "No snapshots found for $target."
        return 1
    fi

    local selection=$(ls -t "$snap_dir"/*.bak 2>/dev/null | xargs -n 1 basename | gum filter --placeholder "Select snapshot to restore...")

    [[ -z "$selection" ]] && return 1

    echo -e "\e[33mSelected: $snap_dir/$selection\e[0m"
    if gum confirm "Restore this snapshot to $config_file?"; then
        cp "$snap_dir/$selection" "$config_file"
        echo "✔ Restoration complete."
        return 0
    else
        return 1
    fi
}

# --- PRIMARY COMMANDS ---

do_setup() {
    echo "Starting ZPWA Setup..."
    local TIMESTAMP=$(date +%Y-%m-%d_%H-%M-%S)
    local MENU_SNAP_DIR="$BASE_DIR/snapshots/menu"

    if [[ -d "$MENU_SNAP_DIR" ]] && ls "$MENU_SNAP_DIR"/*.bak >/dev/null 2>&1; then
        echo -e "\e[33mExisting snapshots detected.\e[0m"
        if gum confirm "Restore a snapshot before proceeding?"; then
            if ! do_restore "menu"; then
                echo "Restore cancelled. Setup aborted."
                return 1
            fi
        fi
    fi

    mkdir -p "$BASE_DIR"/{binds,dispatchers,payloads,scripts/generate,variables,snapshots/bind,snapshots/menu}
    mkdir -p "$HOME/.local/share/omarchy/bin"
    touch "$BASE_DIR/zpwa.index"

    if [ ! -d "$MASTER_SOURCE" ]; then
        echo "Error: Source templates not found."
        exit 1
    fi

    cp -r "$MASTER_SOURCE"/!(conf|cli|zpwa|PKGBUILD|zpwa.install|docs|README.md) "$BASE_DIR/"

    find "$BASE_DIR/scripts" -name "*.sh" -exec chmod +x {} + 2>/dev/null
    chmod +x "$BASE_DIR/omarchy-zenapp-install" "$BASE_DIR/omarchy-zenapp-remove" 2>/dev/null

    ln -sf "$BASE_DIR/omarchy-zenapp-install" "$HOME/.local/share/omarchy/bin/omarchy-zenapp-install"
    ln -sf "$BASE_DIR/omarchy-zenapp-remove" "$HOME/.local/share/omarchy/bin/omarchy-zenapp-remove"

    source "$BASE_DIR/variables/variables.sh"
    bash "$BASE_DIR/scripts/generate/generate_pwa_binds.sh"

    local HYPR_CONF="$HOME/.config/hypr/bindings.conf"
    local BIND_PAYLOAD="$MASTER_SOURCE/conf/payloads/bindings.payload"
    if [ -f "$HYPR_CONF" ] && [ -f "$BIND_PAYLOAD" ]; then
        if ! grep -q "ZEN PWA" "$HYPR_CONF"; then
            cp "$HYPR_CONF" "$BASE_DIR/snapshots/bind/bindings.conf.$TIMESTAMP.bak"
            echo -e "\n" >> "$HYPR_CONF"
            cat "$BIND_PAYLOAD" >> "$HYPR_CONF"
            echo "✔ Binds updated."
        fi
    fi

    do_menu_change
    echo "✔ Setup complete."
}

do_menu_change() {
    local MENU_SH="$HOME/.config/omarchy/extensions/menu.sh"
    local TIMESTAMP=$(date +%Y-%m-%d_%H-%M-%S)
    local MENU_SNAP_DIR="$BASE_DIR/snapshots/menu"

    [[ ! -f "$MENU_SH" ]] && return

    if ls "$MENU_SNAP_DIR"/*.bak >/dev/null 2>&1; then
        if gum confirm "Existing snapshots detected. Restore one before changing style?"; then
            if ! do_restore "menu"; then
                echo "Restore cancelled. Aborting changes."
                return 1
            fi
        fi
    fi

    mkdir -p "$MENU_SNAP_DIR"
    cp "$MENU_SH" "$MENU_SNAP_DIR/menu.sh.$TIMESTAMP.bak"

    local choice=$(gum choose "Replace existing entries" "Add alongside entries")
    [[ -z "$choice" ]] && return

    case "$choice" in
        "Replace existing entries") bash "$MASTER_SOURCE/conf/scripts/replace.sh" "$MENU_SH" "$MASTER_SOURCE/conf/payloads/menu_replace.payload" ;;
        "Add alongside entries") bash "$MASTER_SOURCE/conf/scripts/add.sh" "$MENU_SH" "$MASTER_SOURCE/conf/payloads/menu_add.payload" ;;
    esac
}

do_ls() {
    local INDEX_FILE="$BASE_DIR/zpwa.index"
    echo -e "\e[34m--- Installed Zen PWAs ---\e[0m"
    if [[ -s "$INDEX_FILE" ]]; then
        while IFS='|' read -r sname aname prof desk icon; do
            echo -e " • $aname \e[2m($sname)\e[0m"
        done < "$INDEX_FILE"
    else
        echo "No apps registered."
    fi
}

do_rm_all() {
    local INDEX_FILE="$BASE_DIR/zpwa.index"
    [[ ! -s "$INDEX_FILE" ]] && echo "Nothing to remove." && return

    echo -e "\e[31mPurging ALL Zen PWAs...\e[0m"
    while IFS='|' read -r sname aname prof desk icon; do
        rm -rf "$prof" "$desk" "$icon"
    done < "$INDEX_FILE"
    > "$INDEX_FILE"
    echo "✔ Global cleanup complete."
}

# --- DISPATCHER ---

if [ -z "$1" ]; then show_help; exit 0; fi

case "$1" in
    setup) do_setup ;;
    install) [ "$INITIALIZED" = true ] && present_terminal "omarchy-zenapp-install" 2>/dev/null || echo "Run setup." ;;
    rm)
        [ "$INITIALIZED" = false ] && echo "Run setup." && exit 1
        [[ "$2" == "--all" ]] && do_rm_all || present_terminal "omarchy-zenapp-remove" 2>/dev/null
        ;;
    ls) [ "$INITIALIZED" = true ] && do_ls || echo "Run setup." ;;
    update)
        [ "$INITIALIZED" = false ] && echo "Run setup." && exit 1
        bash "$BASE_DIR/scripts/generate/generate_pwa_binds.sh"
        echo "✔ Binds/Templates refreshed."
        ;;
    monitor)
        if [ "$INITIALIZED" = true ]; then
            bash "$PWA_MONITOR" --verbose
        else
            echo "Run setup."
        fi
        ;;
    menu-change) [ "$INITIALIZED" = true ] && do_menu_change || echo "Run setup." ;;
    restore)
        case "$2" in
            menu) do_restore "menu" ;;
            binds) do_restore "bind" ;;
            *) echo "Usage: zpwa restore [menu|binds]" ;;
        esac
        ;;
    revert)
        echo "Reverting system binds..."
        do_restore "bind"
        echo "Select menu snapshot to revert..."
        do_restore "menu"
        ;;
    -h|--help) show_help ;;
    *) echo "Unknown command: $1"; show_help; exit 1 ;;
esac
